{
  "type": "query",
  "language": "kuery",
  "index": [
    "logs-agentguard.findings-*"
  ],
  "interval": "5m",
  "from": "now-10m",
  "enabled": false,
  "tags": [
    "AgentGuard",
    "AI Activity",
    "MCP",
    "Elastic Security"
  ],
  "references": [
    "https://github.com/Jagadeeshck/integrations/elastic-agentguard#readme"
  ],
  "author": [
    "AgentGuard"
  ],
  "rule_id": "ai-agent-shell-tool-use",
  "name": "AI Agent With Shell Tool Use",
  "description": "Detects untrusted AI agent shell tool execution behavior.",
  "severity": "high",
  "risk_score": 82,
  "query": "event.module: \"agentguard\" and agentguard.finding.type: \"ai_agent_shell_tool_use\" and not agentguard.allowed: true",
  "threat": [
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Execution"
      }
    }
  ]
}
