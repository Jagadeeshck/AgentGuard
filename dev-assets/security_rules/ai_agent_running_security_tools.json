{
  "type": "query",
  "language": "kuery",
  "index": [
    "logs-agentguard.findings-*"
  ],
  "interval": "5m",
  "from": "now-10m",
  "enabled": false,
  "tags": [
    "AgentGuard",
    "AI Activity",
    "MCP",
    "Elastic Security"
  ],
  "references": [
    "https://github.com/Jagadeeshck/integrations/elastic-agentguard#readme"
  ],
  "author": [
    "AgentGuard"
  ],
  "rule_id": "ai-agent-running-security-tools",
  "name": "AI Agent Running Security Tools",
  "description": "Detects untrusted AI agent usage of security tools.",
  "severity": "high",
  "risk_score": 85,
  "query": "event.module: \"agentguard\" and agentguard.cyber_agent.security_tools: * and not agentguard.allowed: true",
  "threat": [
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Discovery"
      }
    },
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Execution"
      }
    },
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Collection"
      }
    }
  ]
}
