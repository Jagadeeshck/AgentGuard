{
  "type": "query",
  "language": "kuery",
  "index": [
    "logs-agentguard.findings-*"
  ],
  "interval": "5m",
  "from": "now-10m",
  "enabled": false,
  "tags": [
    "AgentGuard",
    "AI Activity",
    "MCP",
    "Elastic Security"
  ],
  "references": [
    "https://github.com/Jagadeeshck/integrations/elastic-agentguard#readme"
  ],
  "author": [
    "AgentGuard"
  ],
  "rule_id": "ai-agent-scanning-sensitive-repositories",
  "name": "AI Agent Scanning Sensitive Repositories",
  "description": "Detects untrusted AI agent scanning of sensitive repositories.",
  "severity": "high",
  "risk_score": 84,
  "query": "event.module: \"agentguard\" and agentguard.finding.type: \"ai_agent_sensitive_repo_scan\" and not agentguard.allowed: true",
  "threat": [
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Discovery"
      }
    },
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Collection"
      }
    }
  ]
}
