{
  "type": "query",
  "language": "kuery",
  "index": [
    "logs-agentguard.findings-*"
  ],
  "interval": "5m",
  "from": "now-10m",
  "enabled": false,
  "tags": [
    "AgentGuard",
    "AI Activity",
    "MCP",
    "Elastic Security"
  ],
  "references": [
    "https://github.com/Jagadeeshck/integrations/elastic-agentguard#readme"
  ],
  "author": [
    "AgentGuard"
  ],
  "rule_id": "untrusted-mcp-server-shell-filesystem",
  "name": "Untrusted MCP Server With Shell or Filesystem Access",
  "description": "Detects untrusted MCP servers with shell or filesystem capability.",
  "severity": "high",
  "risk_score": 80,
  "query": "event.module: \"agentguard\" and agentguard.finding.type: \"mcp_server\" and not agentguard.allowed: true and agentguard.mcp.capabilities: (\"shell\" or \"filesystem\")",
  "threat": [
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Discovery"
      }
    },
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Execution"
      }
    },
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "name": "Command and Control"
      }
    }
  ]
}
