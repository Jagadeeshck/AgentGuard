paths:
{{#each paths}}
  - {{this}}
{{/each}}

{{#if pipeline}}
pipeline: {{pipeline}}
{{/if}}

data_stream:
  dataset: {{data_stream.dataset}}

{{#if tags}}
tags:
{{#each tags}}
  - {{this}}
{{/each}}
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{else}}
{{#if preserve_original_event}}
tags:
  - preserve_original_event
{{/if}}
{{/if}}

fields:
  _conf:
    timezone: {{timezone}}

{{#if parsers}}
parsers:
{{parsers}}
{{/if}}

{{#if exclude_files}}
exclude_files:
{{#each exclude_files}}
  - {{this}}
{{/each}}
{{/if}}

{{#if include_files}}
include_files:
{{#each include_files}}
  - {{this}}
{{/each}}
{{/if}}

{{#if ignore_older}}
ignore_older: {{ignore_older}}
{{/if}}

{{#if close_inactive}}
close.on_state_change.inactive: {{close_inactive}}
{{/if}}

{{#if processors}}
processors:
{{processors}}
{{/if}}
