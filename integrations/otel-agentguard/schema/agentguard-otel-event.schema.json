{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentguard.example/schemas/agentguard-otel-event.schema.json",
  "title": "AgentGuard OTEL AI Activity Event",
  "type": "object",
  "required": [
    "agentguard.schema.version",
    "agentguard.source.type",
    "agentguard.source.name",
    "agentguard.provider.name",
    "agentguard.provider.category",
    "agentguard.activity.type",
    "agentguard.finding.id",
    "agentguard.finding.type",
    "agentguard.risk.level",
    "agentguard.risk.score",
    "event.module",
    "event.dataset",
    "observer.vendor",
    "observer.product"
  ],
  "properties": {
    "@timestamp": { "type": "string", "format": "date-time" },
    "agentguard.schema.version": { "type": "string" },
    "agentguard.source.type": { "type": "string", "enum": ["native_otel", "api_gateway", "browser_metadata", "mcp_runtime", "endpoint_sensor", "saas_audit"] },
    "agentguard.source.name": { "type": "string" },
    "agentguard.provider.name": { "type": "string", "enum": ["openai", "anthropic", "google", "microsoft", "perplexity", "mistral", "cohere", "meta", "aws_bedrock", "azure_openai", "local", "unknown"] },
    "agentguard.provider.category": { "type": "string", "enum": ["commercial_ai", "cloud_ai", "coding_assistant", "local_llm", "framework", "mcp", "unknown"] },
    "agentguard.activity.type": { "type": "string", "enum": ["ai_web_session", "ai_api_request", "ai_agent_execution", "ai_tool_invocation", "mcp_server_connection", "mcp_tool_invocation", "local_llm_service_detected", "browser_ai_extension_detected", "model_usage", "policy_match", "privacy_risk", "cost_anomaly", "security_finding"] },
    "agentguard.finding.id": { "type": "string" },
    "agentguard.finding.type": { "type": "string" },
    "agentguard.risk.level": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "agentguard.risk.score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "event.module": { "const": "agentguard" },
    "event.dataset": { "type": "string", "enum": ["agentguard.findings", "agentguard.otel", "agentguard.ai_activity"] },
    "observer.vendor": { "const": "AgentGuard" },
    "observer.product": { "const": "AgentGuard" },
    "agentguard.cost.estimated_usd": { "type": "number" },
    "agentguard.tokens.input": { "type": "integer" },
    "agentguard.tokens.output": { "type": "integer" },
    "agentguard.tokens.total": { "type": "integer" },
    "agentguard.duration.ms": { "type": "integer" },
    "agentguard.privacy.prompt_capture_enabled": { "type": "boolean", "default": false },
    "agentguard.privacy.content_capture_enabled": { "type": "boolean", "default": false },
    "agentguard.privacy.redaction_status": { "type": "string", "default": "metadata_only" },
    "agentguard.attributes": { "type": "object", "additionalProperties": true },
    "agentguard.tool.parameters": { "type": "object", "additionalProperties": true },
    "agentguard.source.raw_metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
